<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.ElderLauncher" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Transparent status and navigation bars for edge-to-edge drawing -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Theme applied to the Android Window while the process is starting (SplashScreen API) -->
    <style name="Theme.ElderLauncher.Launch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/elder_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ElderLauncher</item>
    </style>
</resources>
